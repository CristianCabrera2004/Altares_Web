# Variables de entorno para el Backend - Librería Los Altares
# Copiar este archivo como .env y rellenar los valores reales

# ─── Servidor ────────────────────────────────────
PORT=8080

# ─── Base de Datos PostgreSQL ─────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=app_backend_go
DB_PASSWORD=SuperSecretaApp2026!
DB_NAME=libreria_los_altares
DB_SSLMODE=disable

# ─── Seguridad JWT ────────────────────────────────
# Cambiar por una cadena aleatoria larga y segura en producción
JWT_SECRET=cambia_esta_clave_secreta_por_una_muy_larga_y_segura_2026!

# ─── Configuración de Correo SMTP ──────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_correo@gmail.com
SMTP_PASSWORD=tu_contrasena_de_aplicacion
SMTP_FROM=LibreriaLosAltares <tu_correo@gmail.com>
